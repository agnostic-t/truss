{
  "metadata": {
    "name": "main",
    "version": "0.0.0",
    "priority": 1000
  },

  "code": {
    "sources": ["src/**/*.c"],
    "output": "./bin/main",
    "includes": ["include"],
    "libraries": [
      "picoquic-core",
      "picoquic-log",
      "picotls-core",
      "picotls-minicrypto",
      "picotls-openssl",
      "crypto",
      "sodium"
    ],
    "lib-dirs": ["/usr/local/lib"]
  },

  "dependencies": {
    "threading": { "version": ">=0.0.0" },
    "network": { "version": ">=0.0.0" },
    "containers": { "version": ">=0.0.0" },
    "quic": { "version": ">=0.0.0" },
    "ujson": { "version": ">=0.0.0" },
    "nat": { "version": ">=0.0.0" },
    "argparse": { "version": ">=0.0.0" },
    "p2pnet": { "version": ">=0.0.0" }
  },

  "target": "debug"
}
