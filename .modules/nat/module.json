{
  "metadata": {
    "name": "nat",
    "version": "0.0.0",
    "priority": 100
  },

  "compiler": {
    "binary": "static-lib"
  },

  "dependencies": {
    "network": { "version": ">=0.0.0" },
    "containers": { "version": ">=0.0.0" }
  },

  "code": {
    "sources": ["**/*.c"],
    "output": "./bin/nat",
    "includes": ["include"]
  },

  "target": "debug"
}
