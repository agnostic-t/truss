{
  "metadata": {
    "name": "quic",
    "version": "0.0.0",
    "priority": 3
  },

  "compiler": {
    "binary": "static-lib"
  },

  "dependencies": {
    "network": { "version": ">=0.0.0" },
    "containers": { "version": ">=0.0.0" }
  },

  "code": {
    "sources": ["**/*.c"],
    "output": "./bin/quic",
    "includes": ["include"],
    "libraries": [
      "picoquic-core",
      "picoquic-log",
      "picotls-core",
      "picotls-minicrypto",
      "picotls-openssl"
    ]
  },

  "target": "debug"
}
